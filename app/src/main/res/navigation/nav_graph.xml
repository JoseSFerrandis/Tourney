<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/LoginFragment">

    <fragment
        android:id="@+id/LoginFragment"
        android:name="com.example.tourney.fragments.LoginFragment"
        android:label="@string/login_fragment_label"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_LoginFragment_to_HomeFragment"
            app:destination="@id/HomeFragment" />
        <action
            android:id="@+id/action_LoginFragment_to_RegisterFragment"
            app:destination="@id/RegisterFragment" />
        <action
            android:id="@+id/action_LoginFragment_to_RememberPassword"
            app:destination="@id/RememberPassword" />
    </fragment>

    <fragment
        android:id="@+id/RegisterFragment"
        android:name="com.example.tourney.fragments.RegisterFragment"
        android:label="@string/register_fragment_label"
        tools:layout="@layout/fragment_register" />

    <fragment
        android:id="@+id/RememberPassword"
        android:name="com.example.tourney.fragments.RememberPassword"
        android:label="@string/remember_password_fragment_label"
        tools:layout="@layout/fragment_remember_password">
        <action
            android:id="@+id/action_RememberPassword_to_SetNewPassword"
            app:destination="@id/SetNewPassword" />
    </fragment>

    <fragment
        android:id="@+id/SetNewPassword"
        android:name="com.example.tourney.fragments.SetNewPassword"
        android:label="@string/set_new_password_fragment_label"
        tools:layout="@layout/fragment_set_new_password">
        <action
            android:id="@+id/action_SetNewPassword_to_LoginFragment"
            app:destination="@id/LoginFragment"/>
    </fragment>

    <fragment
        android:id="@+id/HomeFragment"
        android:name="com.example.tourney.fragments.HomeFragment"
        android:label="@string/second_fragment_label"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_HomeFragment_to_LoginFragment"
            app:destination="@id/LoginFragment" />
        <action
            android:id="@+id/action_HomeFragment_to_JoinTournamentFragment"
            app:destination="@id/JoinTournamentFragment" />
        <action
            android:id="@+id/action_HomeFragment_to_ProfileFragment"
            app:destination="@id/ProfileFragment" />
        <action
            android:id="@+id/action_HomeFragment_to_TournamentFragment"
            app:destination="@id/TournamentFragment" />
        <action
            android:id="@+id/action_HomeFragment_to_CreateTournamentFragment"
            app:destination="@id/CreateTournamentFragment" />
    </fragment>

    <fragment
        android:id="@+id/ProfileFragment"
        android:name="com.example.tourney.fragments.AccountManagement"
        android:label="Perfil"
        tools:layout="@layout/fragment_account_management">
        <action
            android:id="@+id/action_ProfileFragment_to_LoginFragment"
            app:destination="@id/LoginFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_ProfileFragment_to_HomeFragment"
            app:destination="@id/HomeFragment" />
        <action
            android:id="@+id/action_ProfileFragment_to_ProfileChooseFragment"
            app:destination="@id/ProfileChooseFragment" />
        <action
            android:id="@+id/action_ProfileFragment_to_privacyFragmentDest"
            app:destination="@id/privacyFragmentDest" />
    </fragment>

    <fragment
        android:id="@+id/ProfileChooseFragment"
        android:name="com.example.tourney.fragments.ProfileChooseFragment"
        android:label="Elegir Avatar"
        tools:layout="@layout/fragment_profile_choose">
        <action
            android:id="@+id/action_ProfileChooseFragment_to_ProfileFragment"
            app:destination="@id/ProfileFragment"
            app:popUpTo="@id/ProfileFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/JoinTournamentFragment"
        android:name="com.example.tourney.fragments.JoinTournamentPage"
        android:label="Unirse al Torneo"
        tools:layout="@layout/fragment_join_tournament_page">
        <action
            android:id="@+id/action_JoinTournamentFragment_to_TournamentFragment"
            app:destination="@id/TournamentFragment" />
    </fragment>

    <fragment
        android:id="@+id/TournamentFragment"
        android:name="com.example.tourney.fragments.TournamentPage"
        android:label="Detalles del Torneo"
        tools:layout="@layout/fragment_tournament_page" >
        <action
            android:id="@+id/action_TournamentFragment_to_HomeFragment"
            app:destination="@id/HomeFragment" />
        <action
            android:id="@+id/action_TournamentFragment_to_ParticipantsListFragment"
            app:destination="@id/ParticipantsListFragment" />
        <action
            android:id="@+id/action_TournamentFragment_to_MatchesFragment"
            app:destination="@id/MatchesFragment" />
        <action
            android:id="@+id/action_TournamentFragment_to_ClasificationListFragment"
            app:destination="@id/ClasificationListFragment" />
        <action
            android:id="@+id/action_TournamentFragment_to_TournamentThumbnailChooseFragment"
            app:destination="@id/TournamentThumbnailChooseFragment" />
        <action
            android:id="@+id/action_TournamentFragment_to_EditTournamentFragment"
            app:destination="@id/EditTournamentFragment" />
        <action
            android:id="@+id/action_TournamentFragment_to_TournamentStandingsFragment"
            app:destination="@id/TournamentStandingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/CreateTournamentFragment"
        android:name="com.example.tourney.fragments.CreateTournamentFragment"
        android:label="Crear Torneo"
        tools:layout="@layout/fragment_create_tournament" >
        <action
            android:id="@+id/action_CreateTournamentFragment_to_TournamentFragment"
            app:destination="@id/TournamentFragment"
            app:popUpTo="@id/CreateTournamentFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_CreateTournamentFragment_to_TournamentThumbnailChooseFragment"
            app:destination="@id/TournamentThumbnailChooseFragment" />
    </fragment>

    <fragment
        android:id="@+id/EditTournamentFragment"
        android:name="com.example.tourney.fragments.EditTournamentFragment"
        android:label="Editar Torneo"
        tools:layout="@layout/fragment_edit_tournament">
        <argument
            android:name="tournament_data"
            app:argType="com.example.tourney.entities.Tournament" />
    </fragment>

    <fragment
        android:id="@+id/ParticipantsListFragment"
        android:name="com.example.tourney.fragments.ParticipantsListFragment"
        android:label="Participantes"
        tools:layout="@layout/fragment_participants_list" />

    <fragment
        android:id="@+id/MatchesFragment"
        android:name="com.example.tourney.fragments.MatchesFragment"
        android:label="Emparejamiento"
        tools:layout="@layout/fragment_matches">
        <action
            android:id="@+id/action_MatchesFragment_to_ClasificationListFragment"
            app:destination="@id/ClasificationListFragment" />
    </fragment>

    <fragment
        android:id="@+id/ClasificationListFragment"
        android:name="com.example.tourney.fragments.ClasificationListFragment"
        android:label="Clasificaciones"
        tools:layout="@layout/fragment_clasification_list">
        <action
            android:id="@+id/action_ClasificationListFragment_to_MatchesFragment"
            app:destination="@id/MatchesFragment" />
    </fragment>

    <fragment
        android:id="@+id/TournamentStandingsFragment"
        android:name="com.example.tourney.fragments.TournamentStandingsFragment"
        android:label="Tabla de Clasificación"
        tools:layout="@layout/fragment_tournament_standings" />

    <fragment
        android:id="@+id/TournamentThumbnailChooseFragment"
        android:name="com.example.tourney.fragments.TournamentThumbnailChooseFragment"
        android:label="Elegir Miniatura"
        tools:layout="@layout/fragment_tournament_thumbnail_choose" />

    <fragment
        android:id="@+id/privacyFragmentDest"
        android:name="com.example.tourney.fragments.TermsDetailFragment"
        android:label="Acuerdo de Confidencialidad"
        tools:layout="@layout/fragment_terms_detail" />

    <fragment
        android:id="@+id/contactFragmentDest"
        android:name="com.example.tourney.fragments.ContactFragment"
        android:label="Contacto"
        tools:layout="@layout/fragment_contact" />

</navigation>