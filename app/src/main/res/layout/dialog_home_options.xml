<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="28dp"
    app:cardElevation="8dp"
    app:strokeWidth="0dp"
    android:backgroundTint="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Qué quieres hacer?"
            android:textColor="@color/blue_600"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

        <!-- Botón Crear: Azul con texto blanco -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateOption"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Crear torneo"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_plus"
            app:iconTint="@color/white"
            app:backgroundTint="@color/boton_movil_card"
            app:cornerRadius="16dp"
            android:layout_marginBottom="16dp"
            app:iconGravity="textStart"
            app:iconPadding="12dp"/>

        <!-- Botón Unirse: Azul con texto blanco -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnJoinOption"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Unirse a un torneo"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_join_tournament"
            app:iconTint="@color/white"
            app:backgroundTint="@color/boton_movil_card"
            app:cornerRadius="16dp"
            app:iconGravity="textStart"
            app:iconPadding="12dp"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>