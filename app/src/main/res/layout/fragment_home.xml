<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient_blue">


        <!-- Header Section (Blue Background) -->
        <LinearLayout
            android:id="@+id/header_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurface"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingBottom="32dp"
            app:layout_constraintTop_toTopOf="parent">

            <!-- User Greeting and Profile Button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <!-- Greeting Text -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hola, Usuario"
                        android:textColor="@color/tablet_title_black"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Encuentra tu próximo desafío"
                        android:textColor="@color/tablet_title_black"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Profile Button -->
                <FrameLayout
                    android:id="@+id/btn_profile"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:clickable="true"
                    android:focusable="true">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_profile"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_gravity="center"
                        android:background="@drawable/ic_user_pfp1"
                        android:gravity="center"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                        app:strokeColor="?attr/colorOnPrimary"
                        android:textStyle="bold" />
                </FrameLayout>
            </LinearLayout>

            <!-- Search Bar -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="48dp">

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/boton_tablet_card"
                    android:hint="Buscar torneos..."
                    android:paddingStart="40dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/white"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:imeOptions="actionSearch" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_search"
                    app:tint="@color/white" />
            </FrameLayout>
        </LinearLayout>

        <!-- Content Section with Rounded Top -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/header_layout"
            app:layout_constraintBottom_toBottomOf="parent"
            android:padding="24dp">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Torneos Disponibles"
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_create_tournament"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginBottom="8dp"
                    android:background="@color/boton_tablet_card"
                    android:drawableStart="@drawable/ic_plus"
                    android:drawablePadding="12dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:text="Crear Torneo"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:gravity="center_vertical|start" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_join_tournament"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@color/boton_tablet_card"
                    android:drawableStart="@drawable/ic_plus"
                    android:drawablePadding="12dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:text="Unirse a un Torneo"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:gravity="center_vertical|start" />
            </LinearLayout>
            <!-- Action Buttons Section -->

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.tabs.TabItem
                    android:id="@+id/page_my_tournaments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mis torneos"/>

                <com.google.android.material.tabs.TabItem
                    android:id="@+id/page_joined_tournaments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inscrito"/>

                <com.google.android.material.tabs.TabItem
                    android:id="@+id/page_following_tournaments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Siguiendo"/>

            </com.google.android.material.tabs.TabLayout>

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/pager"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>