<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient_blue">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- HEADER SECTOR CON IMAGEN DE FONDO -->
                <ImageView
                    android:id="@+id/headerImage"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/dnd_thumbnail"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:ignore="ContentDescription" />

                <!-- Filtro degradado para la imagen -->
                <View
                    android:id="@+id/imageOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:background="#66000000"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- MAIN CONTENT CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardJoin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="-50dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:layout_constraintTop_toBottomOf="@id/headerImage"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <!-- Título de la acción -->
                        <TextView
                            android:id="@+id/tvJoinTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="Unirse al Torneo"
                            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold" />

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginVertical="16dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            android:gravity="center"
                            android:text="Introduce el código de invitación para inscribirte."
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <!-- Input para el código Arreglado -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilTournamentCode"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp"
                            android:hint="Código del Torneo"
                            app:boxStrokeColor="@color/Blue3"
                            app:startIconTint="@color/Blue3"
                            app:startIconScaleType="centerInside"
                            app:endIconMode="clear_text"
                            app:hintTextColor="@color/Blue3">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etTournamentCode"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapCharacters"
                                android:maxLength="10"
                                android:paddingVertical="14dp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Botón de Aceptar Redimensionado -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAcceptJoin"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:text="Confirmar"
                            android:textSize="16sp"
                            android:textColor="@color/white"
                            app:backgroundTint="@color/DarkBlue1"
                            app:icon="@drawable/ic_check"
                            app:iconTint="@color/white"
                            app:iconSize="20dp"
                            app:cornerRadius="12dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Participantes y Reglas -->
                <LinearLayout
                    android:id="@+id/layoutSecondaryActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="32dp"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardJoin"
                    app:layout_constraintVertical_bias="0">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAyuda"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Ayuda"
                        android:textColor="@color/Blue3"
                        app:icon="@drawable/ic_help"
                        app:iconTint="@color/Blue3"
                        app:iconSize="24dp"
                        app:strokeColor="@color/Blue3" />

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>