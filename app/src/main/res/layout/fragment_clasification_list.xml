<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface"
        tools:context=".fragments.ClasificationListFragment">

        <LinearLayout
            android:id="@+id/showParticipants"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNumParticipants"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Participantes vivos: 1/1"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/nextRound"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Empezar torneo"
                    app:cornerRadius="12dp">
                </com.google.android.material.button.MaterialButton>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvParticipants"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_user_add_puntuation" />

            <TextView
                android:id="@+id/tvEmptyList"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No hay participantes inscritos"
                android:layout_gravity="center"
                android:layout_marginTop="100dp"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>