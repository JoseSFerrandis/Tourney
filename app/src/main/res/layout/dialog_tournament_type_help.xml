<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="32dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    android:backgroundTint="@color/white">



        <!-- Cabecera decorativa -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="100dp">


        </FrameLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:src="@drawable/ic_help"
                app:tint="?attr/appColorPrimary"
                android:alpha="0.9" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tipos de Torneo"
                android:textColor="?attr/appColorSecondary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginBottom="24dp"/>

            <!-- Liguilla -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Liguilla"
                android:textColor="?attr/appColorPrimary"
                android:textStyle="bold"
                android:textSize="20sp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Todos los participantes juegan entre sí, y el que acumula más puntos gana."
                android:textColor="@color/black"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <!-- Suizo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Suizo"
                android:textColor="?attr/appColorPrimary"
                android:textStyle="bold"
                android:textSize="20sp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rondas según participantes, enfrentamientos entre jugadores con resultados similares."
                android:textColor="@color/black"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <!-- Eliminación -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Eliminación"
                android:textColor="?attr/appColorPrimary"
                android:textStyle="bold"
                android:textSize="20sp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="El perdedor queda eliminado y el ganador avanza de ronda."
                android:textColor="@color/black"
                android:textSize="14sp"
                android:layout_marginBottom="32dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOk"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Entendido"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:backgroundTint="?attr/appColorPrimary"
                app:cornerRadius="12dp" />

        </LinearLayout>
</com.google.android.material.card.MaterialCardView>