<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface"
        tools:context=".fragments.TournamentPage">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_blue">

                <!-- HEADER SECTOR (Cambiado a ShapeableImageView para consistencia con Tablet) -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/headerImage"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/dnd_thumbnail"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:ignore="ContentDescription" />

                <!-- Filtro degradado -->
                <View
                    android:id="@+id/imageOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:background="#40000000"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- MAIN CONTENT CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardManagement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="-40dp"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="6dp"
                    app:layout_constraintTop_toBottomOf="@id/headerImage"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <!-- Título del Torneo dentro de la Card -->
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/tvTournamentTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:paddingHorizontal="48dp"
                                android:text="Torneo de D&amp;D"
                                android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="end|top"
                                android:orientation="vertical"
                                android:gravity="center_horizontal">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnSettings"
                                    style="@style/Widget.Material3.Button.IconButton"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:layout_marginBottom="8dp"
                                    android:padding="0dp"
                                    android:visibility="gone"
                                    app:iconPadding="0dp"
                                    android:insetTop="0dp"
                                    android:insetBottom="0dp"
                                    android:backgroundTint="@color/boton_tablet_card_white"
                                    app:icon="@drawable/ic_settings"
                                    app:iconSize="22dp"
                                    app:iconTint="@color/boton_movil_card" />

                                <CheckBox
                                    android:id="@+id/btnFollow"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:button="@null"
                                    android:background="@drawable/ic_heart_follow"
                                    android:backgroundTint="@color/follow_button_filled"
                                    android:checked="false" />
                            </LinearLayout>
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_game_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="League of legends"
                            android:textColor="@color/dynamic_text_card"
                            android:gravity="center"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="20dp"/>

                        <!-- Creador y Tipo -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <!-- Creador -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="12dp"
                                    android:layout_height="12dp"
                                    android:src="@drawable/admin"
                                    app:tint="@color/dynamic_text_card" />

                                <TextView
                                    android:id="@+id/tv_creator"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="El creador"
                                    android:textColor="@color/dynamic_text_card"
                                    android:textSize="14sp"
                                    android:layout_marginStart="8dp" />
                            </LinearLayout>

                            <!-- Tipo de torneo -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="12dp"
                                    android:layout_height="12dp"
                                    android:src="@drawable/ic_gravel"
                                    app:tint="@color/dynamic_text_card" />

                                <TextView
                                    android:id="@+id/tv_tournament_type"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Eliminación"
                                    android:textColor="@color/dynamic_text_card"
                                    android:textSize="14sp"
                                    android:layout_marginStart="8dp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Tournament Details Grid -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="16dp">

                            <!-- Participants and Date -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">

                                <!-- Participants -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/ic_users"
                                        app:tint="@color/dynamic_text_card" />

                                    <TextView
                                        android:id="@+id/tv_participants"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="32/32"
                                        android:textColor="@color/dynamic_text_card"
                                        android:textSize="14sp"
                                        android:layout_marginStart="8dp" />
                                </LinearLayout>

                                <!-- Date -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/ic_calendar"
                                        app:tint="@color/dynamic_text_card" />

                                    <TextView
                                        android:id="@+id/tv_date"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="25 Ene 2026"
                                        android:textColor="@color/dynamic_text_card"
                                        android:textSize="14sp"
                                        android:layout_marginStart="8dp" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Location and Prize -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:orientation="horizontal">

                                <!-- Location -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/ic_map_pin"
                                        app:tint="@color/dynamic_text_card" />

                                    <TextView
                                        android:id="@+id/tv_location"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:layout_weight="1"
                                        android:ellipsize="end"
                                        android:maxLines="1"
                                        android:text="Online"
                                        android:textColor="@color/dynamic_text_card"
                                        android:textSize="14sp" />
                                </LinearLayout>

                                <!-- Prize -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/ic_trophy"
                                        app:tint="@color/dynamic_text_card" />

                                    <TextView
                                        android:id="@+id/tv_prize"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="5,000€"
                                        android:textColor="@color/dynamic_text_card"
                                        android:textSize="14sp" />
                                </LinearLayout>


                            </LinearLayout>

                            <!-- Badge -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:layout_marginBottom="16dp">


                                <TextView
                                    android:id="@+id/tv_status_badge"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/bg_badge_open"
                                    android:paddingStart="12dp"
                                    android:paddingTop="4dp"
                                    android:paddingEnd="12dp"
                                    android:paddingBottom="4dp"
                                    android:text="Inscripciones abiertas"
                                    android:textColor="@color/white"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp" />


                        <!-- Botón para unirse al torneo -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnJoin"
                            style="@style/Widget.Material3.Button.ElevatedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:textSize="17dp"
                            android:text="Unirse al torneo"
                            android:textColor="@color/white"
                            app:backgroundTint="@color/blue_600"
                            app:icon="@drawable/ic_join_tournament"
                            app:iconTint="@color/white" />


                        <!-- Clasificación y Emparejamiento con estilo de botón -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClassification"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginBottom="12dp"
                            android:textSize="18sp"
                            android:text="Clasificación"
                            android:textColor="@color/white"
                            app:backgroundTint="@color/boton_tablet_card"
                            app:icon="@drawable/ic_check"
                            app:iconTint="@color/white" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMatches"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:textSize="18sp"
                            android:text="Emparejamientos"
                            android:textColor="@color/white"
                            app:backgroundTint="@color/boton_tablet_card"
                            app:icon="@drawable/ic_settings"
                            app:iconTint="@color/white" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Participantes y Reglas al mismo nivel -->
                <LinearLayout
                    android:id="@+id/layoutSecondaryActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="40dp"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardManagement">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnViewParticipants"
                        android:backgroundTint="@color/boton_tablet_card_white"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:text="Participantes"
                        android:textColor="@color/white"
                        app:icon="@drawable/ic_people"
                        app:iconTint="@color/white" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRules"
                        android:backgroundTint="@color/boton_tablet_card_white"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Reglas"
                        android:textColor="@color/white"
                        app:icon="@drawable/ic_gravel"
                        app:iconTint="@color/white" />

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>