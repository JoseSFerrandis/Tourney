<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface"
        tools:context=".fragments.TournamentPage">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_blue">

                <!-- HEADER SECTOR CON IMAGEN DE FONDO -->
                <ImageView
                    android:id="@+id/headerImage"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/dnd_thumbnail"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:ignore="ContentDescription" />

                <!-- Filtro degradado para la imagen -->
                <View
                    android:id="@+id/imageOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="#40000000"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- MAIN CONTENT CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardManagement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="-40dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:layout_constraintTop_toBottomOf="@id/headerImage"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Título del Torneo dentro de la Card -->
                        <TextView
                            android:id="@+id/tvTournamentTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="Torneo de D&amp;D"
                            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                            android:textColor="?attr/colorOnSurface"
                            android:layout_marginBottom="2dp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_game_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="League of Legends"
                            android:textColor="@color/dynamic_text_card"
                            android:gravity="center"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp"/>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">

                            <!-- Creador -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="12dp"
                                    android:layout_height="12dp"
                                    android:src="@drawable/admin"
                                    app:tint="@color/dynamic_text_card" />

                                <TextView
                                    android:id="@+id/tv_creator"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="El creador"
                                    android:textColor="@color/dynamic_text_card"
                                    android:textSize="14sp"
                                    android:layout_marginStart="8dp" />
                            </LinearLayout>

                            <!-- Tipo de torneo -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="12dp"
                                    android:layout_height="12dp"
                                    android:src="@drawable/ic_gravel"
                                    app:tint="@color/dynamic_text_card" />

                                <TextView
                                    android:id="@+id/tv_tournament_type"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Eliminación"
                                    android:textColor="@color/dynamic_text_card"
                                    android:textSize="14sp"
                                    android:layout_marginStart="8dp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Tournament Details Grid -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- Row 1: Participants and Date -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">

                                <!-- Participants -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/ic_users"
                                        app:tint="@color/dynamic_text_card" />

                                    <TextView
                                        android:id="@+id/tv_participants"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="32/32"
                                        android:textColor="@color/dynamic_text_card"
                                        android:textSize="14sp"
                                        android:layout_marginStart="8dp" />
                                </LinearLayout>

                                <!-- Date -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/ic_calendar"
                                        app:tint="@color/dynamic_text_card" />

                                    <TextView
                                        android:id="@+id/tv_date"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="25 Ene 2026"
                                        android:textColor="@color/dynamic_text_card"
                                        android:textSize="14sp"
                                        android:layout_marginStart="8dp" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Row 2: Location and Prize -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="16dp"
                                android:orientation="horizontal">

                                <!-- Location -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/ic_map_pin"
                                        app:tint="@color/dynamic_text_card" />

                                    <TextView
                                        android:id="@+id/tv_location"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Online"
                                        android:textColor="@color/dynamic_text_card"
                                        android:textSize="14sp"
                                        android:layout_marginStart="8dp"
                                        android:ellipsize="end"
                                        android:maxLines="1" />
                                </LinearLayout>

                                <!-- Prize -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/ic_trophy"
                                        app:tint="@color/dynamic_text_card" />

                                    <TextView
                                        android:id="@+id/tv_prize"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="$5,000"
                                        android:textColor="@color/dynamic_text_card"
                                        android:textSize="14sp"
                                        android:layout_marginStart="8dp" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Badge -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:layout_marginBottom="16dp">
                                <TextView
                                    android:id="@+id/tv_status_badge"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/bg_badge_open"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp"
                                    android:paddingTop="4dp"
                                    android:paddingBottom="4dp"
                                    android:text="Inscripciones Abiertas"
                                    android:textColor="@color/white"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp" />


                        <!-- Clasificación y Emparejamiento con estilo de botón -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClassification"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:textSize="17dp"
                            android:text="Clasificación"
                            android:textColor="@color/white"
                            app:backgroundTint="@color/boton_tablet_card"
                            app:icon="@drawable/ic_check"
                            app:iconTint="@color/white" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMatches"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="17dp"
                            android:text="Emparejamientos"
                            android:textColor="@color/white"
                            app:backgroundTint="@color/boton_tablet_card"
                            app:icon="@drawable/ic_settings"
                            app:iconTint="@color/white" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Participantes y Reglas al mismo nivel -->
                <LinearLayout
                    android:id="@+id/layoutSecondaryActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="32dp"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardManagement"
                    app:layout_constraintVertical_bias="0">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnViewParticipants"
                        android:backgroundTint="@color/boton_tablet_card_white"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:text="Participantes"
                        android:textColor="@color/white"
                        app:icon="@drawable/ic_people"
                        app:iconTint="@color/white"
                        app:strokeColor="@color/white" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRules"
                        android:backgroundTint="@color/boton_tablet_card_white"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Reglas"
                        android:textColor="@color/white"
                        app:icon="@drawable/ic_gravel"
                        app:iconTint="@color/white"
                        app:strokeColor="@color/white" />

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>