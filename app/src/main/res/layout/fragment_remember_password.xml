<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_gradient_blue"
    tools:context=".Fragments.RememberPassword">

    <!-- Contenedor central (flex-1 justify-center items-center) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:text="Recordar contraseña"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Subtítulo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp"
            android:text="Introduzca los siguientes campos"
            android:textColor="#CCDCFF"
            android:textSize="14sp" />

        <!-- Formulario (max-w-sm equivalente) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:maxWidth="384dp">


            <!-- Label Contraseña -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Nickname"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <!-- Input Contraseña -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilRememberNickname"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:endIconMode="password_toggle"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/rememberNicknameInput"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_white"
                    android:hint="Nickname"
                    android:inputType="text"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>


            <!-- Label Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Email"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <!-- Input Email -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilRememberEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/rememberEmailInput"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_white"
                    android:hint="tu@email.com"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>



            <!-- Botón Iniciar Sesión -->
            <Button
                android:id="@+id/btnRememberPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="@android:color/white"
                android:text="Recuperar contraseña"
                android:textColor="@color/blue_600"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
