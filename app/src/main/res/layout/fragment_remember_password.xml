<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@drawable/bg_gradient_blue">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            tools:context=".fragments.RememberPassword">

            <!-- Contenedor central (flex-1 justify-center items-center) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <!-- Título -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="8dp"
                    android:text="Recordar contraseña"
                    android:textColor="@android:color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <!-- Subtítulo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="32dp"
                    android:text="Introduzca los siguientes campos"
                    android:textColor="?attr/appColorSecondaryLight"
                    android:textSize="14sp" />

                <!-- Formulario -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxWidth="384dp"
                    android:orientation="vertical">

                    <!-- Label Nickname -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Nickname"
                        android:textColor="@android:color/white"
                        android:textSize="14sp" />

                    <!-- Input Nickname -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilRememberNickname"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/rememberNicknameInput"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_input_white"
                            android:hint="Nickname"
                            android:inputType="text"
                            android:paddingHorizontal="16dp"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Label Email -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Email"
                        android:textColor="@android:color/white"
                        android:textSize="14sp" />

                    <!-- Input Email -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilRememberEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/rememberEmailInput"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_input_white"
                            android:hint="tu@email.com"
                            android:inputType="textEmailAddress"
                            android:paddingHorizontal="16dp"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>


                <!-- Botón Iniciar Sesión -->
                <Button
                    android:id="@+id/btnRememberPassword"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    android:backgroundTint="@android:color/white"
                    android:text="Recuperar contraseña"
                    android:textColor="?attr/appColorSecondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        </LinearLayout>
    </ScrollView>
</layout>