<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient_blue"
        tools:context=".fragments.SetNewPassword">

        <!-- Contenedor de la Tarjeta (700dp ancho, 900dp alto máximo, centrado) -->
        <LinearLayout
            android:layout_width="700dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_circle_white"
            android:backgroundTint="#1AFFFFFF"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="48dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Ícono de llave/seguridad -->
            <ImageView
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_marginBottom="24dp"
                android:src="@drawable/ic_settings"
                app:tint="@android:color/white" />

            <!-- Título -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Crear nueva contraseña"
                android:textColor="@android:color/white"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textAlignment="center" />

            <!-- Subtítulo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="48dp"
                android:text="Introduzca su nueva contraseña"
                android:textColor="#CCDCFF"
                android:textSize="22sp"
                android:textAlignment="center" />

            <!-- Nueva Contraseña -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilNewPassword"
                android:layout_width="600dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:hint="Nueva contraseña"
                app:hintEnabled="true"
                app:hintTextColor="@android:color/white"
                android:textColorHint="#CCDCFF"
                app:endIconMode="password_toggle"
                app:errorEnabled="true"
                app:endIconTint="@android:color/white">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/newPasswordInput"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:background="@drawable/bg_input_white"
                    android:inputType="textPassword"
                    android:paddingHorizontal="20dp"
                    android:textColor="@color/blue_600"
                    android:textSize="25sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Repetir Contraseña -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilRepeatPassword"
                android:layout_width="600dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                android:hint="Repita su contraseña"
                app:hintEnabled="true"
                app:hintTextColor="@android:color/white"
                android:textColorHint="#CCDCFF"
                app:endIconMode="password_toggle"
                app:errorEnabled="true"
                app:endIconTint="@android:color/white">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/repeatPasswordInput"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:background="@drawable/bg_input_white"
                    android:inputType="textPassword"
                    android:paddingHorizontal="20dp"
                    android:textColor="@color/blue_600"
                    android:textSize="25sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Botón Crear contraseña -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateNewPassword"
                android:layout_width="600dp"
                android:layout_height="80dp"
                android:text="Crear contraseña"
                android:textSize="25sp"
                android:textStyle="bold"
                android:textColor="@color/blue_600"
                app:backgroundTint="@android:color/white"
                app:cornerRadius="20dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>