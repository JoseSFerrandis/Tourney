<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient_blue"
        tools:context=".fragments.MatchesFragment">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="32dp"
            android:backgroundTint="?attr/appColorPrimaryLight"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#33FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="32dp">

                <!-- Header de Botones -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="32dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNextRound"
                        android:layout_width="350dp"
                        android:layout_height="72dp"
                        android:text="Siguiente ronda"
                        android:textColor="@android:color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        app:cornerRadius="16dp"
                        android:backgroundTint="?attr/appColorPrimary"
                        android:layout_marginEnd="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/goToClasification"
                        android:layout_width="350dp"
                        android:layout_height="72dp"
                        android:text="Ir a clasificación"
                        android:textColor="@android:color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        app:cornerRadius="16dp"
                        android:backgroundTint="?attr/appColorPrimary" />
                </LinearLayout>

                <!-- Contenedor del Bracket -->
                <FrameLayout
                    android:id="@+id/bracket_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#0DFFFFFF"
                    android:padding="16dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>