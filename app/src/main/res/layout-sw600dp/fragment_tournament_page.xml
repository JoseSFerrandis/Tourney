<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient_blue">

        <androidx.core.widget.NestedScrollView
            android:layout_width="680dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fillViewport="true"
            android:layout_marginVertical="32dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardManagement"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#1AFFFFFF"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#33FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Top Hero Image -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/headerImage"
                        android:layout_width="match_parent"
                        android:layout_height="260dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/dnd_thumbnail"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.MediumComponent" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="32dp">

                        <!-- Header Info -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <TextView
                                    android:id="@+id/tvTournamentTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Torneo de D&amp;D"
                                    android:layout_gravity="center"
                                    android:paddingHorizontal="64dp"
                                    android:textColor="@android:color/white"
                                    android:textSize="38sp"
                                    android:textStyle="bold"
                                    android:textAlignment="center" />

                                <!-- CONTENEDOR DE ACCIONES -->
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="end|top"
                                    android:orientation="vertical"
                                    android:gravity="center_horizontal">

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/btnSettings"
                                        style="@style/Widget.Material3.Button.IconButton"
                                        android:layout_width="44dp"
                                        android:layout_height="44dp"
                                        android:layout_marginBottom="8dp"
                                        android:padding="0dp"
                                        android:visibility="gone"
                                        app:icon="@drawable/ic_settings"
                                        app:iconSize="24dp"
                                        app:iconTint="@color/boton_movil_card" />

                                    <CheckBox
                                        android:id="@+id/btnFollow"
                                        android:layout_width="44dp"
                                        android:layout_height="44dp"
                                        android:background="@drawable/ic_heart_follow"
                                        android:backgroundTint="@color/follow_button_filled"
                                        android:button="@null"
                                        android:checked="false" />
                                </LinearLayout>
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tv_game_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="League of legends"
                                android:textAlignment="center"
                                android:textColor="#CCDCFF"
                                android:textSize="22sp" />

                            <TextView
                                android:id="@+id/tv_status_badge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="20dp"
                                android:background="@drawable/bg_badge_open"
                                android:paddingHorizontal="18dp"
                                android:paddingVertical="6dp"
                                android:text="Abierto"
                                android:textColor="@android:color/white"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Additional Info Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="32dp"
                                android:gravity="center"
                                android:orientation="horizontal">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/admin"
                                    app:tint="@android:color/white" />
                                <TextView
                                    android:id="@+id/tv_creator"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="Creador"
                                    android:textColor="@android:color/white"
                                    android:textSize="18sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="horizontal">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_gravel"
                                    app:tint="@android:color/white" />
                                <TextView
                                    android:id="@+id/tv_tournament_type"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="Eliminación"
                                    android:textColor="@android:color/white"
                                    android:textSize="18sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Details Row (2 columns) -->
                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="32dp"
                            android:columnCount="2">

                            <!-- Participants -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:layout_marginBottom="16dp"
                                android:gravity="center"
                                android:orientation="vertical">
                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:layout_marginBottom="6dp"
                                    android:src="@drawable/ic_users"
                                    app:tint="@android:color/white" />
                                <TextView
                                    android:id="@+id/tv_participants"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="32/32"
                                    android:textColor="@android:color/white"
                                    android:textSize="18sp" />
                            </LinearLayout>

                            <!-- Date -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:layout_marginBottom="16dp"
                                android:gravity="center"
                                android:orientation="vertical">
                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:layout_marginBottom="6dp"
                                    android:src="@drawable/ic_calendar"
                                    app:tint="@android:color/white" />
                                <TextView
                                    android:id="@+id/tv_date"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="25 Ene 2026"
                                    android:textColor="@android:color/white"
                                    android:textSize="18sp" />
                            </LinearLayout>

                            <!-- Location -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:gravity="center"
                                android:orientation="vertical">
                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:layout_marginBottom="6dp"
                                    android:src="@drawable/ic_map_pin"
                                    app:tint="@android:color/white" />
                                <TextView
                                    android:id="@+id/tv_location"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Online"
                                    android:textColor="@android:color/white"
                                    android:textSize="18sp" />
                            </LinearLayout>

                            <!-- Prize -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:gravity="center"
                                android:orientation="vertical">
                                <ImageView
                                    android:layout_width="26dp"
                                    android:layout_height="26dp"
                                    android:layout_marginBottom="6dp"
                                    android:src="@drawable/ic_trophy"
                                    app:tint="@android:color/white" />
                                <TextView
                                    android:id="@+id/tv_prize"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="5,000€"
                                    android:textColor="@android:color/white"
                                    android:textSize="18sp" />
                            </LinearLayout>
                        </GridLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginBottom="32dp"
                            android:background="#33FFFFFF" />

                        <!-- Main Actions -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:orientation="vertical">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnJoin"
                                android:layout_width="match_parent"
                                android:layout_height="60dp"
                                android:layout_marginBottom="12dp"
                                android:text="Inscribirse"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                app:backgroundTint="@color/blue_600"
                                app:cornerRadius="16dp"
                                app:icon="@drawable/ic_join_tournament"
                                app:iconSize="24dp"
                                app:iconTint="@color/white" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnClassification"
                                android:layout_width="match_parent"
                                android:layout_height="60dp"
                                android:layout_marginBottom="12dp"
                                android:text="Ver clasificación"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                app:backgroundTint="@color/boton_tablet_card"
                                app:cornerRadius="16dp"
                                app:icon="@drawable/ic_check"
                                app:iconSize="24dp"
                                app:iconTint="@color/white" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnMatches"
                                android:layout_width="match_parent"
                                android:layout_height="60dp"
                                android:layout_marginBottom="12dp"
                                android:text="Emparejamientos"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                app:backgroundTint="@color/boton_tablet_card"
                                app:cornerRadius="16dp"
                                app:icon="@drawable/ic_settings"
                                app:iconSize="24dp"
                                app:iconTint="@color/white" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnViewParticipants"
                                android:layout_width="match_parent"
                                android:layout_height="60dp"
                                android:text="Lista de participantes"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                app:backgroundTint="@color/boton_tablet_card"
                                app:cornerRadius="16dp"
                                app:icon="@drawable/ic_people"
                                app:iconSize="24dp"
                                app:iconTint="@color/white" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRules"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:text="Ver reglas del torneo"
                            android:textColor="@android:color/white"
                            android:textSize="16sp"
                            app:cornerRadius="16dp"
                            app:icon="@drawable/ic_gravel"
                            app:iconSize="22dp"
                            app:iconTint="@android:color/white"
                            app:strokeColor="@android:color/white"
                            app:strokeWidth="1dp" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>