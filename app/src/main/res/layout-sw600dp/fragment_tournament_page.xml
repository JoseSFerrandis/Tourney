<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient_blue">

        <androidx.core.widget.NestedScrollView
            android:layout_width="700dp"
            android:layout_height="900dp"
            android:layout_gravity="center"
            android:fillViewport="true">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <!-- MAIN CONTENT CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardManagement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#1AFFFFFF"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#33FFFFFF"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Top Hero Image -->
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/headerImage"
                            android:layout_width="match_parent"
                            android:layout_height="300dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/dnd_thumbnail"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.MediumComponent" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="32dp">

                            <!-- Header Info: Title and Game -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center_horizontal"
                                android:layout_marginBottom="24dp">

                                <TextView
                                    android:id="@+id/tvTournamentTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Torneo de D&amp;D"
                                    android:textColor="@android:color/white"
                                    android:textSize="36sp"
                                    android:textStyle="bold"
                                    android:textAlignment="center" />

                                <TextView
                                    android:id="@+id/tv_game_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="League of Legends"
                                    android:textColor="#CCDCFF"
                                    android:textSize="20sp"
                                    android:textAlignment="center" />

                                <TextView
                                    android:id="@+id/tv_status_badge"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="16dp"
                                    android:background="@drawable/bg_badge_open"
                                    android:paddingHorizontal="20dp"
                                    android:paddingVertical="8dp"
                                    android:text="Inscripciones Abiertas"
                                    android:textColor="@android:color/white"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Additional Info Row (Creator and Type) -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="24dp">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:orientation="horizontal">
                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:src="@drawable/admin"
                                        app:tint="@android:color/white" />
                                    <TextView
                                        android:id="@+id/tv_creator"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="Creador"
                                        android:textColor="@android:color/white"
                                        android:textSize="16sp" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:orientation="horizontal">
                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:src="@drawable/ic_gravel"
                                        app:tint="@android:color/white" />
                                    <TextView
                                        android:id="@+id/tv_tournament_type"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="Eliminación"
                                        android:textColor="@android:color/white"
                                        android:textSize="16sp" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Details Row (2 columns) -->
                            <GridLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:columnCount="2"
                                android:layout_marginBottom="32dp">

                                <!-- Participants -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:gravity="center"
                                    android:layout_marginBottom="16dp"
                                    android:orientation="vertical">
                                    <ImageView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        android:src="@drawable/ic_users"
                                        app:tint="@android:color/white"
                                        android:layout_marginBottom="4dp"/>
                                    <TextView
                                        android:id="@+id/tv_participants"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="32/32"
                                        android:textColor="@android:color/white"
                                        android:textSize="16sp" />
                                </LinearLayout>

                                <!-- Date -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:gravity="center"
                                    android:layout_marginBottom="16dp"
                                    android:orientation="vertical">
                                    <ImageView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        android:src="@drawable/ic_calendar"
                                        app:tint="@android:color/white"
                                        android:layout_marginBottom="4dp"/>
                                    <TextView
                                        android:id="@+id/tv_date"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="25 Ene 2026"
                                        android:textColor="@android:color/white"
                                        android:textSize="16sp" />
                                </LinearLayout>

                                <!-- Location -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:gravity="center"
                                    android:orientation="vertical">
                                    <ImageView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        android:src="@drawable/ic_map_pin"
                                        app:tint="@android:color/white"
                                        android:layout_marginBottom="4dp"/>
                                    <TextView
                                        android:id="@+id/tv_location"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Online"
                                        android:textColor="@android:color/white"
                                        android:textSize="16sp" />
                                </LinearLayout>

                                <!-- Prize -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:gravity="center"
                                    android:orientation="vertical">
                                    <ImageView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        android:src="@drawable/ic_trophy"
                                        app:tint="@android:color/white"
                                        android:layout_marginBottom="4dp"/>
                                    <TextView
                                        android:id="@+id/tv_prize"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="$5,000"
                                        android:textColor="@android:color/white"
                                        android:textSize="16sp" />
                                </LinearLayout>
                            </GridLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginBottom="32dp"
                                android:background="#33FFFFFF" />

                            <!-- Main Actions -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginBottom="16dp">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnClassification"
                                    android:layout_width="match_parent"
                                    android:layout_height="64dp"
                                    android:layout_marginBottom="12dp"
                                    android:text="Ver Clasificación"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/blue_600"
                                    app:backgroundTint="@android:color/white"
                                    app:icon="@drawable/ic_check"
                                    app:iconTint="@color/blue_600"
                                    app:iconSize="24dp"
                                    app:cornerRadius="16dp" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnMatches"
                                    android:layout_width="match_parent"
                                    android:layout_height="64dp"
                                    android:layout_marginBottom="12dp"
                                    android:text="Emparejamientos"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/blue_600"
                                    app:backgroundTint="@android:color/white"
                                    app:icon="@drawable/ic_settings"
                                    app:iconTint="@color/blue_600"
                                    app:iconSize="24dp"
                                    app:cornerRadius="16dp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnViewParticipants"
                                    style="@style/Widget.Material3.Button.OutlinedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="56dp"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="8dp"
                                    android:text="Participantes"
                                    android:textColor="@android:color/white"
                                    android:textSize="14sp"
                                    app:icon="@drawable/ic_people"
                                    app:iconTint="@android:color/white"
                                    app:strokeColor="@android:color/white"
                                    app:cornerRadius="12dp" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnRules"
                                    style="@style/Widget.Material3.Button.OutlinedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="56dp"
                                    android:layout_weight="1"
                                    android:layout_marginStart="8dp"
                                    android:text="Reglas"
                                    android:textColor="@android:color/white"
                                    android:textSize="14sp"
                                    app:icon="@drawable/ic_gravel"
                                    app:iconTint="@android:color/white"
                                    app:strokeColor="@android:color/white"
                                    app:cornerRadius="12dp" />
                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>