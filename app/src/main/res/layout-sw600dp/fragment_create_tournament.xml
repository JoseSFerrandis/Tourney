<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient_blue"
        android:orientation="vertical"
        android:padding="32dp"
        tools:context=".fragments.CreateTournamentFragment">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="760dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bg_circle_white"
                android:backgroundTint="?attr/gradientStartColor"
                android:orientation="vertical"
                android:padding="48dp">

                <!-- Título -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="8dp"
                    android:text="Crear torneo"
                    android:textColor="@android:color/white"
                    android:textSize="56sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="40dp"
                    android:text="Completa los detalles del evento"
                    android:textColor="?attr/appColorSecondaryLight"
                    android:textSize="28sp" />

                <!-- Formulario en Dos Columnas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <!-- Columna 1 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="16dp">

                        <TextView
                            android:id="@+id/tvName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="@string/nombre_Torneo"
                            android:textColor="@android:color/white"
                            android:textSize="20sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            app:helperText="Ej: Copa de Invierno 2026"
                            app:helperTextTextColor="?attr/appColorSecondaryLight"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etName"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:background="@drawable/bg_input_white"
                                android:hint="Nombre del torneo"
                                android:paddingHorizontal="16dp"
                                android:textSize="20sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="Máx. participantes"
                            android:textColor="@android:color/white"
                            android:textSize="20sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilMaxParticipants"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMaxParticipants"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:background="@drawable/bg_input_white"
                                android:hint="32"
                                android:inputType="number"
                                android:paddingHorizontal="16dp"
                                android:textSize="20sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="Ubicación"
                            android:textColor="@android:color/white"
                            android:textSize="20sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etLocation"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:background="@drawable/bg_input_white"
                                android:hint="Estadio virtual, ciudad..."
                                android:paddingHorizontal="16dp"
                                android:textSize="20sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <!-- Columna 2 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:id="@+id/tvGame"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="@string/competicion"
                            android:textColor="@android:color/white"
                            android:textSize="20sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilGame"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            app:helperText="Nombre del juego o deporte"
                            app:helperTextTextColor="?attr/appColorSecondaryLight"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etGame"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:background="@drawable/bg_input_white"
                                android:hint="League of legends"
                                android:paddingHorizontal="16dp"
                                android:textSize="20sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="Fecha"
                            android:textColor="@android:color/white"
                            android:textSize="20sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            app:helperText="Cuándo comenzará la competición"
                            app:helperTextTextColor="?attr/appColorSecondaryLight"
                            app:hintEnabled="false"
                            app:endIconMode="custom"
                            app:endIconDrawable="@drawable/ic_calendar">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etDate"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:background="@drawable/bg_input_white"
                                android:hint="Seleccionar fecha"
                                android:paddingHorizontal="16dp"
                                android:textSize="20sp"
                                android:focusable="false"
                                android:clickable="true" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="Premio"
                            android:textColor="@android:color/white"
                            android:textSize="20sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilPrize"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPrize"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:background="@drawable/bg_input_white"
                                android:hint="5,000€, trofeo..."
                                android:paddingHorizontal="16dp"
                                android:textSize="20sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </LinearLayout>

                <!-- Tipo de Torneo -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tipo de torneo"
                        android:textColor="@android:color/white"
                        android:textSize="20sp" />

                    <ImageButton
                        android:id="@+id/btnTipoTorneoHelp"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="12dp"
                        android:background="@android:color/transparent"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_help"
                        android:tooltipText="Ver ayuda sobre tipos de torneo"
                        app:tint="@android:color/white" />
                </LinearLayout>

                <Spinner
                    android:id="@+id/spTournamentType"
                    android:layout_width="400dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="32dp"
                    android:background="@drawable/bg_input_white"
                    android:paddingHorizontal="16dp"
                    android:theme="@style/ThemeOverlay.AppCompat.Light" />

                <!-- Código (Centrado abajo) -->
                <TextView
                    android:id="@+id/tvCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="8dp"
                    android:text="Código de acceso"
                    android:textColor="@android:color/white"
                    android:textSize="20sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilCode"
                    android:layout_width="400dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="48dp"
                    app:helperText="Código numérico para que otros se unan"
                    app:helperTextTextColor="?attr/appColorSecondaryLight"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCode"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_input_white"
                        android:hint="777"
                        android:inputType="number"
                        android:paddingHorizontal="16dp"
                        android:textSize="20sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Botón Guardar -->
                <Button
                    android:id="@+id/btnCreateTournament"
                    android:layout_width="400dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center_horizontal"
                    android:backgroundTint="@android:color/white"
                    android:text="Crear torneo"
                    android:textColor="?attr/appColorSecondary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:tooltipText="Finalizar y publicar torneo" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</layout>