<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="500dp"
    android:layout_height="wrap_content"
    app:cardCornerRadius="40dp"
    app:cardElevation="12dp"
    app:strokeWidth="0dp"
    android:layout_gravity="center"
    android:backgroundTint="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="48dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Qué quieres hacer?"
            android:textColor="?attr/appColorSecondary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="48dp"/>

        <!-- Opción Editar Detalles -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditDetails"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="Editar detalles"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:icon="@drawable/ic_edit"
            app:iconTint="@color/white"
            app:backgroundTint="?attr/appColorPrimary"
            app:cornerRadius="20dp"
            android:layout_marginBottom="24dp"
            app:iconSize="28dp"
            app:iconGravity="textStart"
            app:iconPadding="16dp" />

        <!-- Botón Editar Imagen -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditThumbnail"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="Editar imagen"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_plus"
            app:iconTint="@color/white"
            app:backgroundTint="?attr/appColorPrimary"
            app:cornerRadius="20dp"
            android:layout_marginBottom="24dp"
            app:iconSize="28dp"
            app:iconGravity="textStart"
            app:iconPadding="16dp"/>

        <!-- Botón Eliminar Torneo -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteTournament"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="Eliminar torneo"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_delete"
            app:iconTint="@color/white"
            app:backgroundTint="@color/design_default_color_error"
            app:cornerRadius="20dp"
            app:iconSize="28dp"
            app:iconGravity="textStart"
            app:iconPadding="16dp"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>