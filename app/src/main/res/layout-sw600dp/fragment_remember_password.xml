<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient_blue"
        tools:context=".fragments.RememberPassword">

        <androidx.core.widget.NestedScrollView
            android:layout_width="760dp"
            android:layout_height="wrap_content"
            android:fillViewport="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/fondo_tablet_card"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#33FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="60dp">

                    <!-- Logo / Ícono superior -->
                    <ImageView
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_marginBottom="24dp"
                        android:src="@mipmap/tourney_logo"
                        app:tint="@android:color/white" />

                    <!-- Título -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recordar contraseña"
                        android:textColor="@android:color/white"
                        android:textSize="62sp"
                        android:textStyle="bold" />

                    <!-- Subtítulo -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Introduzca los siguientes campos"
                        android:textColor="@color/tablet_secondary"
                        android:textSize="30sp" />

                    <View
                        android:layout_width="100dp"
                        android:layout_height="4dp"
                        android:layout_marginVertical="40dp"
                        android:background="@android:color/white" />

                    <!-- Formulario -->
                    <LinearLayout
                        android:layout_width="600dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Nickname -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="Nickname"
                            android:textColor="@android:color/white"
                            android:textSize="30sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilRememberNickname"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="32dp"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/rememberNicknameInput"
                                android:layout_width="match_parent"
                                android:layout_height="76dp"
                                android:background="@drawable/bg_input_white"
                                android:hint="Nickname"
                                android:inputType="text"
                                android:paddingHorizontal="20dp"
                                android:textSize="30sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Email -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="Email"
                            android:textColor="@android:color/white"
                            android:textSize="30sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilRememberEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="48dp"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/rememberEmailInput"
                                android:layout_width="match_parent"
                                android:layout_height="76dp"
                                android:background="@drawable/bg_input_white"
                                android:hint="tu@email.com"
                                android:inputType="textEmailAddress"
                                android:paddingHorizontal="20dp"
                                android:textSize="30sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Botón Recuperar -->
                        <Button
                            android:id="@+id/btnRememberPassword"
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:backgroundTint="@android:color/white"
                            android:text="Recuperar contraseña"
                            android:textColor="@color/blue_600"
                            android:textSize="29sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>