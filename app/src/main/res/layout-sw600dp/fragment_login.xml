<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@drawable/bg_gradient_blue">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="48dp"
            tools:context=".fragments.LoginFragment">

            <!-- Contenedor central (igual que el móvil pero con anchos controlados) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <!-- Ícono trofeo -->
                <FrameLayout
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="32dp"
                    android:background="@drawable/bg_circle_white">

                    <ImageView
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:adjustViewBounds="true"
                        android:contentDescription="TorneoApp"
                        android:scaleType="fitCenter"
                        android:src="@mipmap/tourney_logo"
                        app:tint="?attr/appColorSecondary" />
                </FrameLayout>

                <!-- Título -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="12dp"
                    android:text="Tourney"
                    android:textColor="@android:color/white"
                    android:textSize="42sp"
                    android:textStyle="bold" />

                <!-- Subtítulo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="48dp"
                    android:text="Organiza y participa en torneos"
                    android:textColor="?attr/appColorSecondaryLight"
                    android:textSize="22sp" />

                <!-- Formulario (Ancho limitado a 500dp para tablet) -->
                <LinearLayout
                    android:layout_width="500dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Label Email -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Email"
                        android:textColor="@android:color/white"
                        android:textSize="18sp" />

                    <!-- Input Email -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilLoginEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/loginEmailInput"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_input_white"
                            android:hint="tucorreo@email.com"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/black"
                            android:textColorHint="@color/text_hint"
                            android:paddingHorizontal="24dp"
                            android:textSize="18sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Label Contraseña -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Contraseña"
                        android:textColor="@android:color/white"
                        android:textSize="18sp" />

                    <!-- Input Contraseña -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilLoginPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="32dp"
                        app:endIconMode="password_toggle"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/loginPasswordInput"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_input_white"
                            android:hint="••••••••"
                            android:inputType="textPassword"
                            android:textColor="@color/black"
                            android:textColorHint="@color/text_hint"
                            android:paddingHorizontal="24dp"
                            android:textSize="18sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Botón Iniciar Sesión -->
                    <Button
                        android:id="@+id/btnLoginLogin"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginBottom="12dp"
                        android:backgroundTint="@android:color/white"
                        android:text="Iniciar sesión"
                        android:textColor="?attr/appColorSecondary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <!-- Botón ¿Olvidaste tu contraseña? -->
                    <Button
                        android:id="@+id/btnForgotPassword"
                        style="@style/Widget.AppCompat.Button.Borderless"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:text="¿Olvidaste tu contraseña?"
                        android:textColor="@android:color/white"
                        android:textSize="18sp" />

                    <!-- Botón Modo Invitado -->
                    <Button
                        android:id="@+id/btnModoInvitado"
                        style="@style/Widget.AppCompat.Button.Borderless"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Entrar como invitado"
                        android:textColor="@android:color/white"
                        android:textSize="18sp" />

                </LinearLayout>
            </LinearLayout>

            <!-- Footer: ¿No tienes cuenta? + Crear Cuenta -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="¿No tienes cuenta?"
                    android:textColor="?attr/appColorSecondaryLight"
                    android:textSize="16sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCreateAccount"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="400dp"
                    android:layout_height="72dp"
                    android:text="Crear cuenta"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:letterSpacing="0.02"
                    app:strokeColor="@android:color/white"
                    app:strokeWidth="2dp"
                    app:cornerRadius="16dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</layout>