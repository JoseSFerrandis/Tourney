<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black">

        <!-- Header Section (Tablet Optimized) -->
        <LinearLayout
            android:id="@+id/header_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_blue"
            android:orientation="vertical"
            android:padding="40dp"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="800dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="100dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hola, Usuario"
                        android:textColor="@color/white"
                        android:textSize="42sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Encuentra tu próximo desafío"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/btn_profile"
                    android:layout_width="108dp"
                    android:layout_height="108dp"
                    android:clickable="true"
                    android:layout_marginRight="100dp"
                    android:focusable="true">


                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_profile"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:layout_gravity="center"
                        android:background="@drawable/ic_user_pfp1"
                        android:gravity="center"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                        app:strokeColor="?attr/colorOnPrimary"
                        android:textStyle="bold" />
                </FrameLayout>
            </LinearLayout>

            <FrameLayout
                android:layout_width="800dp"
                android:layout_height="56dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp">

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="600dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_height="match_parent"
                    android:background="@color/boton_tablet_card_white"
                    android:hint="Buscar torneos..."
                    android:paddingStart="56dp"
                    android:paddingEnd="24dp"
                    android:textColor="@color/black"
                    android:textColorHint="@color/black"
                    android:textSize="18sp" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="120dp"
                    android:src="@drawable/ic_search"
                    app:tint="@color/black" />
            </FrameLayout>
        </LinearLayout>

        <!-- Content Section adapted for TabLayout + ViewPager2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="-24dp"
            android:background="@drawable/bg_content_rounded_top"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header_layout">

            <LinearLayout
                android:layout_width="800dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="40dp">

                <!-- Title -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    android:text="Torneos Disponibles"
                    android:textColor="@color/black"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <!-- Action Buttons (Side by Side on Tablet) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_create_tournament"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="12dp"
                        android:background="@color/boton_tablet_card"
                        android:drawableStart="@drawable/ic_plus"
                        android:drawablePadding="16dp"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"
                        android:text="Crear Torneo"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:gravity="center_vertical|start" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_join_tournament"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:background="@color/boton_tablet_card"
                        android:drawableStart="@drawable/ic_plus"
                        android:drawablePadding="16dp"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"
                        android:text="Unirse a un Torneo"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:gravity="center_vertical|start" />
                </LinearLayout>

                <!-- TabLayout matching mobile logic -->
                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tab_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:tabTextColor="@color/text_secondary"
                    app:tabSelectedTextColor="@color/boton_tablet_card">

                    <com.google.android.material.tabs.TabItem
                        android:id="@+id/page_my_tournaments"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mis torneos"/>

                    <com.google.android.material.tabs.TabItem
                        android:id="@+id/page_joined_tournaments"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Inscrito"/>

                    <com.google.android.material.tabs.TabItem
                        android:id="@+id/page_following_tournaments"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Siguiendo"/>

                </com.google.android.material.tabs.TabLayout>

                <!-- ViewPager2 replacing static RecyclerView -->
                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/pager"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>