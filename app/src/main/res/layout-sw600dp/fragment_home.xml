<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black">

        <!-- Header Section (Tablet Optimized) -->
        <LinearLayout
            android:id="@+id/header_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_blue"
            android:orientation="vertical"
            android:padding="40dp"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="700dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="177dp"
                    android:layout_height="101dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_greeting"
                        android:layout_width="222dp"
                        android:layout_height="wrap_content"
                        android:text="Hola, Usuario"
                        android:textColor="@color/white"
                        android:textSize="32sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Encuentra tu próximo desafío"
                        android:textColor="@color/white"
                        android:textSize="23sp" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/btn_profile"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_profile_button">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_profile_avatar"
                        android:gravity="center"
                        android:text="U"
                        android:textColor="@color/blue_600"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </FrameLayout>
            </LinearLayout>

            <FrameLayout
                android:layout_width="800dp"
                android:layout_height="56dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp">

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_search_input"
                    android:hint="Buscar torneos..."
                    android:paddingStart="56dp"
                    android:paddingEnd="24dp"
                    android:textColor="@color/black"
                    android:textColorHint="@color/black"
                    android:textSize="18sp" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="20dp"
                    android:src="@drawable/ic_search"
                    app:tint="@color/black" />
            </FrameLayout>
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="-24dp"
            android:background="@drawable/bg_content_rounded_top"
            android:fillViewport="true"
            app:layout_constraintTop_toBottomOf="@id/header_layout"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="800dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="30dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Torneos Disponibles"
                    android:textColor="@color/black"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="22dp" />

                <!-- Action Buttons (Side by Side on Tablet) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="40dp">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_create_tournament"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_button_create"
                        android:drawableStart="@drawable/ic_plus"
                        android:drawablePadding="16dp"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"
                        android:text="@string/crear_torneo"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:gravity="center_vertical|start" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_join_tournament"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_button_create"
                        android:drawableStart="@drawable/ic_plus"
                        android:drawablePadding="16dp"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"
                        android:text="@string/Join_Tournament"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:gravity="center_vertical|start" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_tournaments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="2"
                    tools:listitem="@layout/item_tournament_card" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>