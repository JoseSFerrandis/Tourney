<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient_blue">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="700dp"
            android:layout_height="0dp"
            android:layout_marginVertical="64dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#33FFFFFF"
            android:backgroundTint="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="48dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Términos y Condiciones Detallados"
                    android:textColor="?attr/appColorPrimaryDark"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="32dp"/>

                <androidx.core.widget.NestedScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:textSize="20sp"
                        android:lineSpacingExtra="8dp"
                        android:text="Aquí se detallan todos los términos y condiciones de la aplicación Tourney para su versión de Tablet.\n\n1. Uso de la cuenta: El usuario es responsable de mantener la confidencialidad de sus datos y del uso que se haga de su cuenta.\n\n2. Participación en Torneos: Al inscribirse en un torneo, el usuario acepta las reglas específicas establecidas por el organizador y el sistema de juego seleccionado.\n\n3. Privacidad de Datos: Sus datos personales (email, nickname) solo se utilizan para la gestión de torneos locales y la personalización de la experiencia de usuario.\n\n4. Uso de Cookies y Almacenamiento: Tourney utiliza almacenamiento local para guardar sus preferencias de tema, su estado de sesión y su consentimiento de privacidad.\n\n5. Responsabilidad: Tourney es una herramienta de gestión y no se hace responsable de las disputas externas entre jugadores.\n\nContinúe usando la app de forma responsable y competitiva." />
                </androidx.core.widget.NestedScrollView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackTerms"
                    android:layout_width="300dp"
                    android:layout_height="72dp"
                    android:layout_marginTop="32dp"
                    android:layout_gravity="center_horizontal"
                    android:text="Cerrar y Volver"
                    android:textSize="20sp"
                    android:textAllCaps="false"
                    app:backgroundTint="?attr/appColorPrimary"
                    app:cornerRadius="16dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>